<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.starrysky.lifemini.mapper.UserMapper">

    <select id="queryUserInfoList" resultType="com.starrysky.lifemini.model.dto.UserInfoDTO">
        select id,
        username,
        avatar
        from tb_user
        <where>
            <if test="status != null">
                and status = #{status}
            </if>
            and id in
            <foreach collection="userIds" item="userId" open="(" separator="," close=")">
                #{userId}
            </foreach>
        </where>
    </select>
</mapper>
